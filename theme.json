{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "layout": {
            "contentSize": "800px",
            "wideSize": "1140px"
        },
        "color": {
            "defaultPalette": false,
            "defaultGradients": false,
            "palette": [
                { "slug": "base", "color": "#111111", "name": "Base" },
                { "slug": "contrast", "color": "#E0DDD5", "name": "Contrast" },
                { "slug": "secondary", "color": "#a2a09a", "name": "Secondary" },
                { "slug": "muted", "color": "#595856", "name": "Muted" },
                { "slug": "ghost", "color": "rgba(224,221,213,0.09)", "name": "Ghost" },

                { "slug": "yellow", "color": "#FFEE58", "name": "Yellow" },
                { "slug": "green", "color": "#22c55e", "name": "Green" },
                { "slug": "purple", "color": "#7c3aed", "name": "Purple" },
                { "slug": "purple-light", "color": "#a78bfa", "name": "Purple Light" },

                { "slug": "yellow-tint", "color": "rgba(255,238,88,0.07)", "name": "Yellow Tint" },
                { "slug": "yellow-border", "color": "rgba(255,238,88,0.17)", "name": "Yellow Border" },
                { "slug": "green-tint", "color": "rgba(34,197,94,0.07)", "name": "Green Tint" },
                { "slug": "green-border", "color": "rgba(34,197,94,0.17)", "name": "Green Border" },
                { "slug": "purple-tint", "color": "rgba(124,58,237,0.07)", "name": "Purple Tint" },
                { "slug": "purple-border", "color": "rgba(124,58,237,0.16)", "name": "Purple Border" },

                { "slug": "glass", "color": "rgba(255,255,255,0.025)", "name": "Glass" },
                { "slug": "glass-border", "color": "rgba(255,255,255,0.055)", "name": "Glass Border" },
                { "slug": "glass-hover", "color": "rgba(255,255,255,0.11)", "name": "Glass Hover" },

                { "slug": "light-base", "color": "#F5F4F0", "name": "Light Base" },
                { "slug": "light-surface", "color": "#ECEAE4", "name": "Light Surface" },
                { "slug": "light-contrast", "color": "#1C1915", "name": "Light Contrast" },
                { "slug": "light-secondary", "color": "#2E2A24", "name": "Light Secondary" },
                { "slug": "light-muted", "color": "#7A7268", "name": "Light Muted" },
                { "slug": "light-border", "color": "rgba(50,44,36,0.12)", "name": "Light Border" },
                { "slug": "light-border-hover", "color": "rgba(50,44,36,0.26)", "name": "Light Border Hover" },
                { "slug": "light-amber", "color": "#8B6914", "name": "Light Amber" },

                { "slug": "cat-module", "color": "#5aaedc", "name": "Module" },
                { "slug": "cat-skill", "color": "#6bba6e", "name": "Skill" },
                { "slug": "cat-agent", "color": "#d47898", "name": "Agent" },
                { "slug": "cat-workflow", "color": "#9b7dd4", "name": "Workflow" },
                { "slug": "cat-protocol", "color": "#d4924c", "name": "Protocol" },
                { "slug": "cat-changelog", "color": "#a8d44c", "name": "Changelog" }
            ]
        },
        "typography": {
            "defaultFontSizes": false,
            "fluid": true,
            "fontSizes": [
                { "slug": "small", "size": "14px", "name": "Small", "fluid": false },
                { "slug": "terminal", "size": "16px", "name": "Terminal", "fluid": false },
                { "slug": "medium", "size": "19px", "name": "Medium", "fluid": { "min": "17px", "max": "19px" } },
                { "slug": "body", "size": "21px", "name": "Body", "fluid": { "min": "17px", "max": "21px" } },
                { "slug": "body-large", "size": "23px", "name": "Body Large", "fluid": { "min": "19px", "max": "23px" } },
                { "slug": "large", "size": "clamp(1.4rem, 2.5vw, 1.8rem)", "name": "Large" },
                { "slug": "x-large", "size": "clamp(1.8rem, 3vw, 2.6rem)", "name": "XL" },
                { "slug": "hero", "size": "clamp(3rem, 5.5vw, 5rem)", "name": "Hero" }
            ],
            "fontFamilies": [
                {
                    "fontFamily": "Syne, sans-serif",
                    "name": "Syne",
                    "slug": "syne",
                    "fontFace": [{
                        "fontFamily": "Syne",
                        "fontWeight": "400 800",
                        "fontStyle": "normal",
                        "src": ["file:./assets/fonts/Syne-Variable.woff2"]
                    }]
                },
                {
                    "fontFamily": "Manrope, system-ui, sans-serif",
                    "name": "Manrope",
                    "slug": "manrope",
                    "fontFace": [{
                        "fontFamily": "Manrope",
                        "fontWeight": "200 800",
                        "fontStyle": "normal",
                        "src": ["file:./assets/fonts/Manrope-Variable.woff2"]
                    }]
                },
                {
                    "fontFamily": "'JetBrains Mono', monospace",
                    "name": "JetBrains Mono",
                    "slug": "jetbrains-mono",
                    "fontFace": [{
                        "fontFamily": "JetBrains Mono",
                        "fontWeight": "400 700",
                        "fontStyle": "normal",
                        "src": ["file:./assets/fonts/JetBrainsMono-Variable.woff2"]
                    }]
                }
            ]
        },
        "spacing": {
            "defaultSpacingSizes": false,
            "units": ["px", "rem", "%", "vw"],
            "spacingSizes": [
                { "slug": "10", "size": "8px", "name": "1 — Tight" },
                { "slug": "20", "size": "16px", "name": "2 — Compact" },
                { "slug": "30", "size": "24px", "name": "3 — Default" },
                { "slug": "40", "size": "36px", "name": "4 — Comfortable" },
                { "slug": "50", "size": "48px", "name": "5 — Loose" },
                { "slug": "60", "size": "clamp(48px, 5vw, 64px)", "name": "6 — Section" },
                { "slug": "70", "size": "clamp(56px, 7vw, 80px)", "name": "7 — Region" },
                { "slug": "80", "size": "clamp(64px, 10vw, 120px)", "name": "8 — Hero" }
            ]
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "custom": {
            "border": {
                "subtle": "rgba(255,255,255,0.055)",
                "default": "rgba(255,255,255,0.08)",
                "strong": "rgba(255,255,255,0.11)"
            },
            "lineHeight": {
                "tight": "1.03",
                "heading": "1.12",
                "body": "1.82",
                "loose": "1.9"
            },
            "letterSpacing": {
                "tight": "-0.045em",
                "heading": "-0.03em",
                "label": "0.1em"
            },
            "radius": {
                "card": "8px",
                "segment": "12px",
                "terminal": "14px",
                "pill": "100px"
            }
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--base)",
            "text": "var(--wp--preset--color--contrast)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--manrope)",
            "fontSize": "var(--wp--preset--font-size--medium)",
            "fontWeight": "300",
            "lineHeight": "var(--wp--custom--line-height--body)"
        },
        "spacing": {
            "blockGap": "24px",
            "padding": {
                "left": "clamp(24px, 5vw, 56px)",
                "right": "clamp(24px, 5vw, 56px)"
            }
        },
        "elements": {
            "link": {
                "color": { "text": "var(--wp--preset--color--yellow)" },
                ":hover": { "color": { "text": "var(--wp--preset--color--contrast)" } }
            },
            "heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--syne)",
                    "fontWeight": "700",
                    "letterSpacing": "var(--wp--custom--letter-spacing--heading)"
                },
                "color": { "text": "var(--wp--preset--color--contrast)" }
            },
            "h1": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--hero)",
                    "fontWeight": "800",
                    "lineHeight": "var(--wp--custom--line-height--tight)",
                    "letterSpacing": "var(--wp--custom--letter-spacing--tight)"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--x-large)",
                    "lineHeight": "var(--wp--custom--line-height--heading)"
                },
                "spacing": { "margin": { "top": "3rem" } }
            },
            "h3": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--large)",
                    "fontWeight": "700",
                    "lineHeight": "1.25"
                }
            },
            "h4": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
                    "fontSize": "var(--wp--preset--font-size--small)",
                    "fontWeight": "500",
                    "textTransform": "uppercase",
                    "letterSpacing": "var(--wp--custom--letter-spacing--label)"
                },
                "color": { "text": "var(--wp--preset--color--muted)" }
            },
            "caption": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
                    "fontSize": "var(--wp--preset--font-size--small)"
                },
                "color": { "text": "var(--wp--preset--color--muted)" }
            }
        },
        "blocks": {
            "core/code": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
                    "fontSize": "var(--wp--preset--font-size--terminal)",
                    "lineHeight": "var(--wp--custom--line-height--loose)"
                },
                "color": {
                    "background": "rgba(255,255,255,0.015)",
                    "text": "var(--wp--preset--color--secondary)"
                },
                "border": {
                    "color": "var(--wp--custom--border--subtle)",
                    "width": "1px",
                    "radius": "var(--wp--custom--radius--terminal)"
                },
                "spacing": {
                    "padding": {
                        "top": "1.5rem",
                        "right": "1.5rem",
                        "bottom": "1.5rem",
                        "left": "1.5rem"
                    }
                }
            },
            "core/preformatted": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
                    "fontSize": "var(--wp--preset--font-size--terminal)"
                },
                "color": {
                    "background": "rgba(255,255,255,0.015)",
                    "text": "var(--wp--preset--color--secondary)"
                }
            },
            "core/separator": {
                "color": { "text": "var(--wp--custom--border--subtle)" },
                "border": { "color": "currentColor" }
            },
            "core/quote": {
                "border": {
                    "color": "var(--wp--preset--color--yellow)",
                    "width": "3px"
                },
                "color": {
                    "background": "var(--wp--preset--color--yellow-tint)"
                },
                "spacing": {
                    "padding": {
                        "top": "1rem",
                        "right": "1.25rem",
                        "bottom": "1rem",
                        "left": "1.25rem"
                    }
                }
            },
            "core/navigation": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--small)",
                    "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)"
                }
            },
            "core/post-title": {
                "typography": {
                    "fontWeight": "800",
                    "letterSpacing": "var(--wp--custom--letter-spacing--tight)"
                }
            },
            "core/post-date": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
                    "fontSize": "var(--wp--preset--font-size--small)"
                },
                "color": { "text": "var(--wp--preset--color--muted)" }
            },
            "core/post-terms": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
                    "fontSize": "var(--wp--preset--font-size--small)"
                }
            },
            "core/post-excerpt": {
                "color": { "text": "var(--wp--preset--color--secondary)" }
            },
            "core/search": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--small)"
                }
            },
            "core/query-title": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--x-large)",
                    "fontWeight": "800"
                }
            },
            "core/table": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--terminal)"
                }
            }
        }
    },
    "templateParts": [
        { "name": "header", "title": "Header", "area": "header" },
        { "name": "footer", "title": "Footer", "area": "footer" },
        { "name": "sidebar", "title": "Sidebar", "area": "uncategorized" }
    ]
}
