{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "layout": {
            "contentSize": "740px",
            "wideSize": "1200px"
        },
        "color": {
            "defaultPalette": false,
            "defaultGradients": false,
            "palette": [
                { "slug": "base", "color": "#0e0e10", "name": "Base" },
                { "slug": "surface", "color": "#141416", "name": "Surface" },
                { "slug": "raised", "color": "#1a1a1e", "name": "Raised" },
                { "slug": "overlay", "color": "#222228", "name": "Overlay" },
                { "slug": "contrast", "color": "#e8e6e0", "name": "Contrast" },
                { "slug": "secondary", "color": "#cccac4", "name": "Secondary" },
                { "slug": "muted", "color": "#7a7874", "name": "Muted" },
                { "slug": "accent", "color": "#c9a84c", "name": "Accent" },
                { "slug": "cat-module", "color": "#5aaedc", "name": "Module" },
                { "slug": "cat-skill", "color": "#6bba6e", "name": "Skill" },
                { "slug": "cat-agent", "color": "#d47898", "name": "Agent" },
                { "slug": "cat-workflow", "color": "#9b7dd4", "name": "Workflow" },
                { "slug": "cat-protocol", "color": "#d4924c", "name": "Protocol" },
                { "slug": "cat-changelog", "color": "#a8d44c", "name": "Changelog" },
                { "slug": "light-base", "color": "#F2EFE9", "name": "Light Base" },
                { "slug": "light-surface", "color": "#EAE6DF", "name": "Light Surface" },
                { "slug": "light-contrast", "color": "#1C1915", "name": "Light Contrast" }
            ]
        },
        "typography": {
            "defaultFontSizes": false,
            "fluid": true,
            "fontSizes": [
                { "slug": "small", "size": "14px", "name": "Small", "fluid": false },
                { "slug": "medium", "size": "18px", "name": "Medium", "fluid": { "min": "16px", "max": "18px" } },
                { "slug": "large", "size": "20px", "name": "Large", "fluid": { "min": "18px", "max": "20px" } },
                { "slug": "x-large", "size": "clamp(1.5rem, 3vw, 2.25rem)", "name": "XL" },
                { "slug": "xx-large", "size": "clamp(1.875rem, 4vw, 2.667rem)", "name": "2XL" },
                { "slug": "hero", "size": "clamp(3rem, 5.5vw, 5rem)", "name": "Hero" }
            ],
            "fontFamilies": [
                {
                    "fontFamily": "Syne, sans-serif",
                    "name": "Syne",
                    "slug": "syne",
                    "fontFace": [
                        {
                            "fontFamily": "Syne",
                            "fontWeight": "400 800",
                            "fontStyle": "normal",
                            "src": ["file:./assets/fonts/Syne-Variable.woff2"]
                        }
                    ]
                },
                {
                    "fontFamily": "'JetBrains Mono', monospace",
                    "name": "JetBrains Mono",
                    "slug": "jetbrains-mono",
                    "fontFace": [
                        {
                            "fontFamily": "JetBrains Mono",
                            "fontWeight": "400 700",
                            "fontStyle": "normal",
                            "src": ["file:./assets/fonts/JetBrainsMono-Variable.woff2"]
                        }
                    ]
                },
                {
                    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif",
                    "name": "System",
                    "slug": "system"
                }
            ]
        },
        "spacing": {
            "units": ["px", "rem", "%", "vw"],
            "spacingSizes": [
                { "slug": "10", "size": "8px", "name": "1" },
                { "slug": "20", "size": "16px", "name": "2" },
                { "slug": "30", "size": "24px", "name": "3" },
                { "slug": "40", "size": "36px", "name": "4" },
                { "slug": "50", "size": "48px", "name": "5" },
                { "slug": "60", "size": "64px", "name": "6" },
                { "slug": "70", "size": "80px", "name": "7" },
                { "slug": "80", "size": "120px", "name": "8" }
            ]
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "custom": {
            "border": {
                "subtle": "rgba(255,255,255,0.06)",
                "default": "rgba(255,255,255,0.10)",
                "strong": "rgba(255,255,255,0.20)"
            },
            "accent": {
                "dim": "rgba(201,168,76,0.14)",
                "glow": "rgba(201,168,76,0.07)"
            },
            "layout": {
                "sidebarWidth": "273px",
                "tocWidth": "240px",
                "topbarHeight": "64px",
                "tabstripHeight": "48px",
                "headerTotal": "112px"
            }
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--base)",
            "text": "var(--wp--preset--color--contrast)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--syne)",
            "fontSize": "var(--wp--preset--font-size--medium)",
            "lineHeight": "1.75"
        },
        "spacing": {
            "blockGap": "24px"
        },
        "elements": {
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--accent)"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--contrast)"
                    }
                }
            },
            "heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--syne)",
                    "fontWeight": "700",
                    "letterSpacing": "-0.03em"
                },
                "color": {
                    "text": "var(--wp--preset--color--contrast)"
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--xx-large)",
                    "fontWeight": "800",
                    "lineHeight": "1.15",
                    "letterSpacing": "-0.03em"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--x-large)",
                    "lineHeight": "1.3",
                    "letterSpacing": "-0.025em"
                },
                "spacing": {
                    "margin": {
                        "top": "3rem"
                    }
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "clamp(1.1rem, 2vw, 1.2rem)",
                    "fontWeight": "600",
                    "lineHeight": "1.4"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "0.9rem",
                    "fontWeight": "700",
                    "textTransform": "uppercase",
                    "letterSpacing": "0.07em"
                },
                "color": {
                    "text": "var(--wp--preset--color--muted)"
                }
            },
            "caption": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
                    "fontSize": "var(--wp--preset--font-size--small)"
                },
                "color": {
                    "text": "var(--wp--preset--color--muted)"
                }
            }
        },
        "blocks": {
            "core/code": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
                    "fontSize": "0.9rem",
                    "lineHeight": "1.7"
                },
                "color": {
                    "background": "var(--wp--preset--color--raised)",
                    "text": "var(--wp--preset--color--secondary)"
                },
                "border": {
                    "color": "var(--wp--custom--border--default)",
                    "width": "1px",
                    "radius": "8px"
                },
                "spacing": {
                    "padding": {
                        "top": "1.375rem",
                        "right": "1.375rem",
                        "bottom": "1.375rem",
                        "left": "1.375rem"
                    }
                }
            },
            "core/preformatted": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
                    "fontSize": "0.875rem"
                },
                "color": {
                    "background": "var(--wp--preset--color--raised)",
                    "text": "var(--wp--preset--color--secondary)"
                }
            },
            "core/separator": {
                "color": {
                    "text": "var(--wp--custom--border--subtle)"
                },
                "border": {
                    "color": "currentColor"
                }
            },
            "core/table": {
                "typography": {
                    "fontSize": "0.9rem"
                }
            },
            "core/quote": {
                "border": {
                    "color": "var(--wp--preset--color--accent)",
                    "width": "3px"
                },
                "color": {
                    "background": "var(--wp--custom--accent--dim)"
                },
                "spacing": {
                    "padding": {
                        "top": "0.875rem",
                        "right": "1.125rem",
                        "bottom": "0.875rem",
                        "left": "1.125rem"
                    }
                }
            },
            "core/navigation": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--small)"
                }
            },
            "core/post-title": {
                "typography": {
                    "fontWeight": "800",
                    "letterSpacing": "-0.03em"
                }
            },
            "core/post-date": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
                    "fontSize": "0.75rem"
                },
                "color": {
                    "text": "var(--wp--preset--color--muted)"
                }
            },
            "core/post-terms": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
                    "fontSize": "0.75rem"
                }
            },
            "core/post-excerpt": {
                "color": {
                    "text": "var(--wp--preset--color--secondary)"
                }
            },
            "core/search": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--small)"
                }
            },
            "core/query-title": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--xx-large)",
                    "fontWeight": "800"
                }
            }
        }
    },
    "customTemplates": [
        {
            "name": "docs-landing",
            "title": "Docs Landing",
            "postTypes": ["page"]
        }
    ],
    "templateParts": [
        { "name": "header", "title": "Header", "area": "header" },
        { "name": "footer", "title": "Footer", "area": "footer" },
        { "name": "sidebar", "title": "Sidebar", "area": "uncategorized" }
    ]
}
